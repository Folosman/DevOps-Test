pipeline {
    agent {
        docker {
            image 'ubuntu:24.04'
            args '-u root:root'
        }
    }

    stages {
        stage('Build Conan Package') {
            steps {
                sh '''
                    apt-get update
                    apt-get install -y \
                        python3 python3-pip \
                        build-essential \
                        cmake git

                    python3 -m pip install --break-system-packages "conan>=2,<3"

                    conan --version

                    conan profile detect --force

                    conan create . \
                        --version=1.0.0 \
                        -s build_type=Release \
                        -o shared=False \
                        --build=missing
                '''
            }
        }
    }
}